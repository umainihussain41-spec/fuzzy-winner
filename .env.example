# ─── Exotel Credentials ───────────────────────────────────────────────────────
# Get these from: https://my.exotel.com → Settings → API
EXOTEL_ACCOUNT_SID=your_account_sid_here
EXOTEL_API_KEY=your_api_key_here
EXOTEL_API_TOKEN=your_api_token_here
# Your Exotel virtual number (Exophone)
EXOTEL_CALLER_ID=+91XXXXXXXXXX
# Region: use 'in' for India (api.in.exotel.com) or 'sg' for Singapore (api.exotel.com)
EXOTEL_REGION=in

# ─── Groq LLM (Free) ──────────────────────────────────────────────────────────
# Sign up free at: https://console.groq.com (no credit card needed)
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Sarvam AI — STT + TTS (Free Trial Credits) ───────────────────────────────
# Sign up at: https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# ─── Server Config ────────────────────────────────────────────────────────────
PORT=3000
# Your public WebSocket URL (use ngrok for local dev: ngrok http 3000)
# Example: wss://abc123.ngrok.io
PUBLIC_WS_URL=wss://your-public-url.ngrok.io

# ─── Bot Behaviour ────────────────────────────────────────────────────────────
# TTS voice for Indian English accent
SARVAM_SPEAKER=anushka
# Language code for Indian English
SARVAM_LANGUAGE=en-IN
# LLM model (Groq free tier)
GROQ_MODEL=llama-3.3-70b-versatile
# VAD silence threshold in ms (how long to wait after speech stops before sending to STT)
VAD_SILENCE_MS=700
# Audio buffer chunk size (ms)
AUDIO_CHUNK_MS=300
